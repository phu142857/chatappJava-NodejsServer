<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable raised emboss (rectangle). Radius matches reference mock. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:top="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_lg" />
            <solid android:color="@color/neu_emboss_shadow" />
        </shape>
    </item>

    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_lg" />
            <solid android:color="@color/neu_emboss_highlight" />
        </shape>
    </item>

    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_lg" />
            <gradient
                android:angle="90"
                android:endColor="@color/neu_emboss_face_end"
                android:startColor="@color/neu_emboss_face_start"
                android:type="linear" />
        </shape>
    </item>

</layer-list>
