<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- outer shadow -->
    <item android:top="4dp">
        <shape android:shape="oval">
            <solid android:color="@color/neu_emboss_shadow" />
        </shape>
    </item>

    <!-- top highlight -->
    <item android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/neu_emboss_highlight" />
        </shape>
    </item>

    <!-- red raised face -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="oval">
            <gradient
                android:angle="90"
                android:endColor="@color/neu_copper_accent_dark"
                android:startColor="@color/neu_copper_accent_light"
                android:type="linear" />
        </shape>
    </item>

</layer-list>
