<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.08"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top"
            android:orientation="vertical"
            android:paddingStart="@dimen/margin_mobile"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingEnd="@dimen/margin_mobile"
            android:paddingBottom="@dimen/spacing_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/auth_top_cluster"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/auth_logo_bezel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_bezel_outer"
                        android:padding="@dimen/spacing_xs">

                        <ImageView
                            android:id="@+id/login_title_top"
                            android:layout_width="@dimen/auth_logo_size"
                            android:layout_height="@dimen/auth_logo_size"
                            android:background="@drawable/bg_bezel_inner"
                            android:contentDescription="@string/auth_app_icon_cd"
                            android:padding="@dimen/auth_logo_padding"
                            android:src="@mipmap/ic_launcher_round" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_auth_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/auth_title_margin_top"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/auth_title_sign_in"
                        android:textAppearance="@style/AppHeadlineLarge"
                        android:textColor="@color/neu_copper_ink" />

                    <TextView
                        android:id="@+id/tv_auth_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/auth_subtitle_margin_top"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:gravity="start"
                        android:text="@string/auth_subtitle"
                        android:textAppearance="@style/AppBodyMedium"
                        android:textColor="@color/neu_copper_ink_muted" />

                    <FrameLayout
                        android:id="@+id/auth_switch_container"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/auth_switch_height"
                        android:layout_marginTop="@dimen/auth_switch_margin_top"
                        android:background="@drawable/bg_neu_copper_sunken_pill"
                        android:padding="@dimen/auth_switch_inner_padding">

                        <View
                            android:id="@+id/auth_tab_indicator"
                            android:layout_width="1dp"
                            android:layout_height="@dimen/auth_tab_height"
                            android:background="@drawable/bg_auth_tab_indicator_outline" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/auth_tab_height"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_sign_in_tab"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:gravity="center"
                                android:minHeight="@dimen/auth_tab_height"
                                android:text="@string/auth_sign_in_tab"
                                android:textColor="@color/tab_text_selector"
                                android:textSize="@dimen/text_body_large"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_register"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:gravity="center"
                                android:minHeight="@dimen/auth_tab_height"
                                android:text="@string/auth_sign_up_tab"
                                android:textColor="@color/tab_text_selector"
                                android:textSize="@dimen/text_body_large"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </FrameLayout>

                </LinearLayout>

                <FrameLayout
                    android:id="@+id/auth_form_bezel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/auth_form_margin_top"
                    android:background="@drawable/bg_bezel_outer"
                    android:padding="@dimen/bezel_shell_padding">

                    <FrameLayout
                        android:id="@+id/auth_form_stage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_bezel_inner"
                        android:minHeight="@dimen/auth_form_min_height"
                        android:paddingStart="@dimen/auth_card_padding_h"
                        android:paddingTop="@dimen/auth_card_padding_v"
                        android:paddingEnd="@dimen/auth_card_padding_h"
                        android:paddingBottom="@dimen/auth_card_padding_v">

                    <LinearLayout
                        android:id="@+id/login_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_label_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:labelFor="@+id/et_email"
                            android:text="@string/label_email"
                            android:textAppearance="@style/AppLabelSmall"
                            android:textColor="@color/neu_copper_ink" />

                        <EditText
                            android:id="@+id/et_email"
                            style="@style/AppInputField"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_field_height"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:gravity="center_vertical"
                            android:hint="@string/hint_enter_email"
                            android:imeOptions="actionNext"
                            android:inputType="textEmailAddress"
                            android:textCursorDrawable="@null" />

                        <TextView
                            android:id="@+id/tv_label_password"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:labelFor="@+id/et_password"
                            android:text="@string/label_password"
                            android:textColor="@color/neu_copper_ink"
                            android:textSize="@dimen/text_body_large"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_password"
                            style="@style/AppInputField"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_field_height"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:drawableEnd="@drawable/ic_eye_off"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:hint="@string/hint_enter_password"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:textCursorDrawable="@null" />

                        <TextView
                            android:id="@+id/tv_forgot_password"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="@dimen/touch_target_min"
                            android:text="@string/forgot_password"
                            android:textColor="@color/text_accent"
                            android:textSize="@dimen/text_body_medium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_login_error"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:accessibilityLiveRegion="polite"
                            android:text=""
                            android:textColor="@color/danger"
                            android:textSize="@dimen/text_body_small"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/btn_login"
                            style="@style/AppPrimaryButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dialog_padding_v"
                            android:text="@string/btn_sign_in" />

                        <TextView
                            android:id="@+id/tv_server_endpoint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:minHeight="@dimen/touch_target_min"
                            android:textColor="@color/md3_on_surface_secondary"
                            android:textSize="@dimen/text_body_small"
                            tools:text="Server: http://192.168.2.28:49664" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/register_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_label_username"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:labelFor="@+id/et_username"
                            android:text="@string/label_username"
                            android:textColor="@color/neu_copper_ink"
                            android:textSize="@dimen/text_body_large"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_username"
                            style="@style/AppInputField"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_field_height"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:gravity="center_vertical"
                            android:hint="@string/hint_choose_username"
                            android:imeOptions="actionNext"
                            android:inputType="text"
                            android:textCursorDrawable="@null" />

                        <TextView
                            android:id="@+id/tv_label_register_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:labelFor="@+id/et_register_email"
                            android:text="@string/label_email"
                            android:textColor="@color/neu_copper_ink"
                            android:textSize="@dimen/text_body_large"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_register_email"
                            style="@style/AppInputField"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_field_height"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:gravity="center_vertical"
                            android:hint="@string/hint_enter_email"
                            android:imeOptions="actionNext"
                            android:inputType="textEmailAddress"
                            android:textCursorDrawable="@null" />

                        <TextView
                            android:id="@+id/tv_label_register_password"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:labelFor="@+id/et_register_password"
                            android:text="@string/label_password"
                            android:textColor="@color/neu_copper_ink"
                            android:textSize="@dimen/text_body_large"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_register_password"
                            style="@style/AppInputField"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_field_height"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:drawableEnd="@drawable/ic_eye_off"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:hint="@string/hint_create_password"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:textCursorDrawable="@null" />

                        <TextView
                            android:id="@+id/tv_label_confirm_password"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:labelFor="@+id/et_confirm_password"
                            android:text="@string/label_confirm_password"
                            android:textColor="@color/neu_copper_ink"
                            android:textSize="@dimen/text_body_large"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_confirm_password"
                            style="@style/AppInputField"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_field_height"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:drawableEnd="@drawable/ic_eye_off"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:hint="@string/hint_confirm_password_field"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:textCursorDrawable="@null" />

                        <TextView
                            android:id="@+id/tv_register_error"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:accessibilityLiveRegion="polite"
                            android:text=""
                            android:textColor="@color/danger"
                            android:textSize="@dimen/text_body_small"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/btn_register"
                            style="@style/AppPrimaryButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dialog_padding_v"
                            android:text="@string/btn_sign_up" />

                    </LinearLayout>

                    </FrameLayout>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
