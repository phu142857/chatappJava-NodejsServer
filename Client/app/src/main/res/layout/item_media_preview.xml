<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="120dp"
    android:layout_height="120dp"
    android:layout_marginEnd="@dimen/spacing_sm"
    android:background="@drawable/bg_soft_inset"
    android:clipChildren="true"
    android:clipToPadding="true">

    <ImageView
        android:id="@+id/iv_media_thumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/media_preview_cd"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/shadow_tint_subtle" />

    <ImageView
        android:id="@+id/iv_video_indicator"
        android:layout_width="@dimen/touch_target_min"
        android:layout_height="@dimen/touch_target_min"
        android:layout_gravity="center"
        android:background="@drawable/bg_send_circle_modern"
        android:padding="10dp"
        android:src="@drawable/ic_play"
        android:visibility="gone"
        app:tint="@color/md3_on_surface" />

    <ImageButton
        android:id="@+id/iv_remove_media"
        android:layout_width="@dimen/media_remove_button_size"
        android:layout_height="@dimen/media_remove_button_size"
        android:layout_gravity="top|end"
        android:layout_margin="7dp"
        android:background="@drawable/bg_icon_circle_dark"
        android:contentDescription="@string/remove_media_cd"
        android:padding="9dp"
        android:src="@drawable/ic_close"
        app:tint="@color/md3_primary" />

</FrameLayout>
