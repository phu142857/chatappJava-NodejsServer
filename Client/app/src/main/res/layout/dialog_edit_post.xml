<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_neu_emboss_raised_md">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_edit_post_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="@dimen/dialog_padding_h" />

        <!-- Content EditText -->
        <EditText
            android:id="@+id/et_edit_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="130dp"
            android:maxLines="10"
            android:inputType="textMultiLine|textCapSentences"
            android:hint="@string/home_create_post_hint"
            android:gravity="top|start"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="@dimen/spacing_md"
            android:background="@drawable/bg_soft_inset"
            android:textColor="@color/md3_on_surface"
            android:textColorHint="@color/md3_on_surface_secondary"
            android:textSize="15sp"
            android:textCursorDrawable="@null"
            android:overScrollMode="never" />

        <!-- Privacy Settings -->
        <LinearLayout
            android:id="@+id/ll_edit_privacy_settings"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_option_row_dark"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_eye"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/post_privacy_label"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/md3_on_surface" />

            <TextView
                android:id="@+id/tv_edit_privacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/post_privacy_public"
                android:textSize="14sp"
                android:textColor="@color/md3_on_surface_secondary"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_more"
                app:tint="@color/md3_on_surface_secondary" />

        </LinearLayout>

        <!-- Separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/md3_border_subtle"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="16dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical">

            <!-- Cancel Button -->
            <LinearLayout
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_target_min"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_filter_pill_inactive"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_cancel"
                    android:textSize="15sp"
                    android:textColor="@color/dialog_button_secondary_text"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Save Button -->
            <LinearLayout
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_target_min"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_button_normal_ripple"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_save"
                    android:textSize="15sp"
                    android:textColor="@color/dialog_button_filled_text"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>