<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_lg"
    android:paddingEnd="@dimen/bubble_padding_h"
    android:paddingTop="@dimen/spacing_xs"
    android:paddingBottom="@dimen/spacing_xs"
    android:clipToPadding="false"
    android:clipChildren="false">

    <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:minHeight="46dp"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:background="@color/brand_red_glow" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="top"
        android:clipToPadding="false"
        android:clipChildren="false">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_reply_avatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_profile_placeholder"
            app:civ_border_color="@color/md3_border_subtle"
            app:civ_border_width="@dimen/avatar_border_width_sm" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_xs"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:clipChildren="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="110dp"
                android:maxWidth="260dp"
                android:orientation="vertical"
                android:paddingStart="@dimen/bubble_padding_h"
                android:paddingEnd="@dimen/bubble_padding_h"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm"
                android:background="@drawable/bg_message_received">

                <TextView
                    android:id="@+id/tv_reply_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="220dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/username"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="@dimen/text_banner"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingBottom="3dp"
                    tools:text="Username" />

                <TextView
                    android:id="@+id/tv_reply_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/preview_comment_reply"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="@dimen/text_banner"
                    android:lineSpacingExtra="3dp"
                    android:linksClickable="true"
                    android:autoLink="web"
                    tools:text="This is a reply to the comment." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="5dp"
                android:layout_marginStart="@dimen/spacing_xs"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_reply_timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/preview_time_ago_short"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:textSize="@dimen/text_tab_label" />

                <TextView
                    android:id="@+id/tv_reply_likes_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/touch_target_min"
                    android:minWidth="@dimen/touch_target_min"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/badge_count_placeholder"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="@dimen/text_tab_label"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingStart="@dimen/spacing_xs"
                    android:paddingEnd="@dimen/spacing_xs"
                    android:background="@drawable/bg_badge_red_modern"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_reply_like"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:minHeight="@dimen/touch_target_min"
                    android:minWidth="@dimen/touch_target_min"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/post_like"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:textSize="@dimen/text_tab_label"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:background="@drawable/bg_icon_circle_transparent" />

                <TextView
                    android:id="@+id/tv_reply_reply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:minHeight="@dimen/touch_target_min"
                    android:minWidth="@dimen/touch_target_min"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/dialog_option_reply"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:textSize="@dimen/text_tab_label"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:background="@drawable/bg_icon_circle_transparent" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
