<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dialog_padding_h"
        android:paddingEnd="@dimen/dialog_padding_h"
        android:paddingTop="@dimen/dialog_padding_v"
        android:paddingBottom="@dimen/dialog_padding_h"
        android:background="@drawable/bg_neu_emboss_raised_md">

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_member_options_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="@dimen/dialog_padding_h" />

        <!-- Member Info Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:background="@drawable/bg_option_row_dark"
            android:layout_marginBottom="12dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_member_avatar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_profile_placeholder"
                app:civ_border_width="1.5dp"
                app:civ_border_color="@color/md3_border_glow" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/tv_member_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/display_name_placeholder"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/neu_copper_ink"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_member_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@username"
                    android:textSize="13sp"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:layout_marginTop="3dp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:src="@drawable/ic_close"
                android:contentDescription="@string/close_cd"
                android:background="@drawable/bg_icon_circle_dark"
                android:padding="@dimen/icon_button_inset"
                app:tint="@color/neu_copper_accent" />

        </LinearLayout>

        <!-- View Profile Option -->
        <LinearLayout
            android:id="@+id/option_view_profile"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_info"
                android:layout_marginEnd="12dp"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_member_view_profile"
                style="@style/AppBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Transfer Ownership Option -->
        <LinearLayout
            android:id="@+id/option_transfer_ownership"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/touch_target_min"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_more"
                android:layout_marginEnd="12dp"
                app:tint="@color/warning_color" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_member_transfer_ownership"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Promote to Moderator Option -->
        <LinearLayout
            android:id="@+id/option_promote_to_moderator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/touch_target_min"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_more"
                android:layout_marginEnd="12dp"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_member_promote"
                style="@style/AppBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Demote to Member Option -->
        <LinearLayout
            android:id="@+id/option_demote_to_member"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/touch_target_min"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_option_row_dark"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_more"
                android:layout_marginEnd="12dp"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_member_demote"
                style="@style/AppBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Remove Member Option -->
        <LinearLayout
            android:id="@+id/option_remove_member"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/touch_target_min"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_danger_option_row"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_delete"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_error" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_member_remove"
                android:textSize="15sp"
                android:textColor="@color/dialog_button_destructive_text"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>