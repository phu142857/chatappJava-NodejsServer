<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_screen_dark"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/app_bar"
        layout="@layout/component_neu_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width" />

    <!-- Scrollable Content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/app_bar"
        app:layout_constraintBottom_toTopOf="@id/ll_reply_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/margin_mobile"
                android:paddingEnd="@dimen/margin_mobile"
                android:paddingTop="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_lg">

                <!-- Full Post Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_full_post"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:background="@drawable/bg_soft_inset">

                        <!-- Header Block -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingBottom="12dp">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/iv_post_avatar"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_profile_placeholder"
                                app:civ_border_color="@color/md3_border_glow"
                                app:civ_border_width="1.5dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/tv_post_username"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/preview_display_name"
                                        android:textColor="@color/neu_copper_ink"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tv_post_tagged_users"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:text=""
                                        android:textColor="@color/text_white"
                                        android:textSize="16sp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:background="@drawable/bg_icon_circle_transparent"
                                        android:visibility="gone" />

                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tv_post_timestamp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                android:text=""
                                    android:textColor="@color/neu_copper_ink_muted"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <ImageButton
                                android:id="@+id/iv_post_menu"
                                android:layout_width="@dimen/touch_target_min"
                                android:layout_height="@dimen/touch_target_min"
                                android:background="@drawable/bg_neu_copper_sunken_circle"
                                android:src="@drawable/ic_more"
                                android:contentDescription="@string/post_options_cd"
                                android:padding="9dp"
                                app:tint="@color/neu_copper_ink_muted" />

                        </LinearLayout>

                        <!-- Content Body -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingBottom="12dp">

                            <TextView
                                android:id="@+id/tv_post_content"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/neu_copper_ink"
                                android:textSize="15sp"
                                android:lineSpacingMultiplier="1.2"
                                android:paddingBottom="10dp" />

                            <FrameLayout
                                android:id="@+id/fl_post_media"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="200dp"
                                android:visibility="gone"
                                android:background="@drawable/bg_option_row_dark"
                                android:clipToOutline="true">

                                <ImageView
                                    android:id="@+id/iv_post_image"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:scaleType="centerCrop"
                                    android:adjustViewBounds="true"
                                    android:visibility="gone" />

                                <androidx.recyclerview.widget.RecyclerView
                                    android:id="@+id/rv_post_gallery"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:visibility="gone"
                                    android:scrollbars="none" />

                                <FrameLayout
                                    android:id="@+id/fl_post_video"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:minHeight="300dp"
                                    android:visibility="gone"
                                    android:background="@color/video_stage">

                                    <ImageView
                                        android:id="@+id/iv_post_video_thumbnail"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:scaleType="centerCrop"
                                        android:adjustViewBounds="true" />

                                    <ImageButton
                                        android:id="@+id/iv_post_video_play"
                                        android:layout_width="64dp"
                                        android:layout_height="64dp"
                                        android:layout_gravity="center"
                                        android:background="@drawable/bg_send_circle_modern"
                                        android:src="@drawable/ic_play"
                                        android:contentDescription="@string/post_play_video_cd"
                                        android:padding="18dp"
                                        app:tint="@color/neu_copper_ink" />

                                </FrameLayout>

                            </FrameLayout>

                        </LinearLayout>

                        <!-- Interaction Summary -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp">

                            <LinearLayout
                                android:id="@+id/ll_likes_summary"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_emoji_smile"
                                    app:tint="@color/neu_copper_accent" />

                                <TextView
                                    android:id="@+id/tv_likes_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="5dp"
                                    android:text="@string/preview_likes_count"
                                    android:textColor="@color/neu_copper_ink_muted"
                                    android:textSize="14sp" />

                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_comments_count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/post_comments_count"
                                android:textColor="@color/neu_copper_ink_muted"
                                android:textSize="14sp"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="end"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tv_shares_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/preview_shares_count"
                                android:textColor="@color/neu_copper_ink_muted"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/md3_border_subtle"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="6dp" />

                        <!-- Action Bar -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <LinearLayout
                                android:id="@+id/ll_like_button"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/touch_target_min"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="@drawable/bg_icon_circle_transparent">

                                <ImageView
                                    android:id="@+id/iv_like_icon"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_emoji_smile"
                                    app:tint="@color/neu_copper_accent" />

                                <TextView
                                    android:id="@+id/tv_like_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="@string/post_like"
                                    android:textColor="@color/neu_copper_ink"
                                    android:textSize="14sp" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/ll_comment_button"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/touch_target_min"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="@drawable/bg_icon_circle_transparent">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_chat"
                                    app:tint="@color/neu_copper_accent" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="@string/post_comment"
                                    android:textColor="@color/neu_copper_ink"
                                    android:textSize="14sp" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/ll_share_button"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/touch_target_min"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="@drawable/bg_icon_circle_transparent">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_open"
                                    app:tint="@color/neu_copper_accent" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="@string/post_share"
                                    android:textColor="@color/neu_copper_ink"
                                    android:textSize="14sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Comments Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="14dp">

                    <TextView
                        android:id="@+id/tv_comments_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/comments_title"
                        android:textColor="@color/neu_copper_ink"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="10dp" />

                    <include
                        android:id="@+id/list_skeleton"
                        layout="@layout/component_list_skeleton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/ll_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="28dp"
                        android:paddingEnd="28dp"
                        android:paddingTop="34dp"
                        android:paddingBottom="34dp"
                        android:visibility="gone"
                        android:background="@drawable/bg_soft_inset">

                        <ImageView
                            android:layout_width="68dp"
                            android:layout_height="68dp"
                            android:src="@drawable/ic_chat"
                            android:background="@drawable/bg_icon_circle_dark"
                            android:padding="16dp"
                            app:tint="@color/neu_copper_accent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/comments_empty_title"
                            android:textColor="@color/neu_copper_ink"
                            android:textStyle="bold"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/comments_empty_subtitle"
                            android:textColor="@color/neu_copper_ink_muted"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_comments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="8dp"
                        android:nestedScrollingEnabled="false"
                        android:scrollbars="none" />

                    <TextView
                        android:id="@+id/tv_load_more_comments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/comments_view_more"
                        android:textColor="@color/neu_copper_ink"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_new_message_button"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="9dp"
                        android:paddingBottom="9dp"
                        android:visibility="gone"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Reply Indicator -->
    <LinearLayout
        android:id="@+id/ll_reply_indicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:background="@drawable/bg_reply_bar_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_sm"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/ll_input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width">

        <View
            android:layout_width="3dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_reply_line" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_replying_to"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/replying_to"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_white" />

            <TextView
                android:id="@+id/tv_reply_target_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/username"
                android:textSize="14sp"
                android:textColor="@color/neu_copper_ink"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/iv_cancel_reply"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/close_reply_description"
            android:padding="9dp"
            app:tint="@color/neu_copper_ink_muted" />

    </LinearLayout>

    <!-- Flat comment input dock -->
    <LinearLayout
        android:id="@+id/ll_input_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neu_composer_dock"
        android:gravity="center_vertical"
        android:minHeight="@dimen/nav_bar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingBottom="@dimen/spacing_xs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="@dimen/search_bar_height"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/bg_soft_inset">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_comment_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_profile_placeholder"
                app:civ_border_color="@color/md3_border_glow"
                app:civ_border_width="1dp" />

            <EditText
                android:id="@+id/et_comment_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:minHeight="40dp"
                android:maxHeight="120dp"
                android:background="@android:color/transparent"
                android:hint="@string/comment_hint"
                android:textColorHint="@color/neu_copper_ink_muted"
                android:textColor="@color/neu_copper_ink"
                android:textSize="14sp"
                android:inputType="textCapSentences|textMultiLine"
                android:gravity="center_vertical|start"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:textCursorDrawable="@null"
                android:scrollbars="vertical"
                android:overScrollMode="always" />

            <ImageButton
                android:id="@+id/iv_attach_media"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:background="@drawable/bg_icon_circle_transparent"
                android:src="@drawable/ic_camera"
                android:contentDescription="@string/attach_media_cd"
                android:padding="8dp"
                android:visibility="visible"
                app:tint="@color/neu_copper_accent" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/iv_send_comment"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_send_circle_modern"
            android:src="@drawable/ic_send"
            android:contentDescription="@string/send_comment_cd"
            android:padding="13dp"
            android:enabled="false"
            app:tint="@color/neu_copper_ink" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>