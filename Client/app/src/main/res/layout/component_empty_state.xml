<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_neu_copper_raised_rect"
    android:padding="@dimen/spacing_md">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <FrameLayout
            android:id="@+id/empty_icon_shell"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:background="@drawable/bg_neu_copper_sunken_circle"
            android:padding="@dimen/spacing_sm"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:id="@+id/iv_empty_icon"
                android:layout_width="@dimen/avatar_sm"
                android:layout_height="@dimen/avatar_sm"
                android:importantForAccessibility="no"
                android:visibility="gone"
                app:tint="@color/neu_copper_accent"
                tools:src="@drawable/ic_chat"
                tools:visibility="visible" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_empty_title"
            style="@style/AppHeadlineSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/neu_copper_ink"
            tools:text="No messages yet" />

        <TextView
            android:id="@+id/tv_empty_subtitle"
            style="@style/AppBodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:gravity="center"
            android:textColor="@color/neu_copper_ink_muted"
            tools:text="Start a conversation to see it here." />

    </LinearLayout>

</FrameLayout>
