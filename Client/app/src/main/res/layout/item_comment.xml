<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/margin_mobile"
    android:paddingEnd="@dimen/margin_mobile"
    android:paddingTop="@dimen/spacing_sm"
    android:paddingBottom="@dimen/spacing_sm"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:clipToPadding="false"
        android:clipChildren="false">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_comment_avatar"
            android:layout_width="@dimen/avatar_sm"
            android:layout_height="@dimen/avatar_sm"
            android:contentDescription="@string/home_create_post_avatar_cd"
            android:src="@drawable/ic_profile_placeholder"
            app:civ_border_color="@color/md3_border_subtle"
            app:civ_border_width="@dimen/avatar_border_width_sm"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:clipChildren="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:minWidth="130dp"
                android:paddingStart="@dimen/bubble_padding_h"
                android:paddingEnd="@dimen/bubble_padding_h"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm"
                android:background="@drawable/bg_message_received">

                <TextView
                    android:id="@+id/tv_comment_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:text=""
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="@dimen/text_body_medium"
                    tools:text="Username"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingBottom="5dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tv_comment_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="260dp"
                    android:text=""
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="@dimen/text_body_medium"
                    android:lineSpacingExtra="@dimen/list_item_margin"
                    tools:text="Comment text"
                    android:linksClickable="true"
                    android:autoLink="web"
                    android:longClickable="true" />

                <ImageView
                    android:id="@+id/iv_comment_media"
                    android:layout_width="260dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:maxHeight="200dp"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:visibility="gone"
                    android:background="@drawable/bg_soft_inset"
                    android:contentDescription="@string/comment_media_cd" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginStart="@dimen/spacing_xs"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_comment_timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/preview_time_ago"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:textSize="@dimen/text_body_small" />

                <TextView
                    android:id="@+id/tv_comment_like"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:minHeight="@dimen/touch_target_min"
                    android:minWidth="@dimen/touch_target_min"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/post_like"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_body_small"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:background="@drawable/bg_icon_circle_transparent" />

                <TextView
                    android:id="@+id/tv_comment_reply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:minHeight="@dimen/touch_target_min"
                    android:minWidth="@dimen/touch_target_min"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/dialog_option_reply"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_body_small"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:background="@drawable/bg_icon_circle_transparent" />

                <LinearLayout
                    android:id="@+id/ll_reaction_icons_inline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:minHeight="@dimen/touch_target_min"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:background="@drawable/bg_soft_inset"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_reaction_like"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_reaction_like"
                        android:textSize="18sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_love"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_reaction_love"
                        android:textSize="18sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_haha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_reaction_haha"
                        android:textSize="18sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_wow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_reaction_wow"
                        android:textSize="18sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_sad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_reaction_sad"
                        android:textSize="18sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_reaction_angry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_reaction_angry"
                        android:textSize="18sp"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_comment_reaction_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/touch_target_min"
                    android:minWidth="@dimen/touch_target_min"
                    android:layout_marginStart="4dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/badge_count_placeholder"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="@dimen/text_body_small"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="@dimen/spacing_xs"
                    android:paddingEnd="@dimen/spacing_xs"
                    android:background="@drawable/bg_badge_red_modern"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/iv_comment_menu"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:background="@drawable/bg_icon_circle_transparent"
                    android:src="@drawable/ic_more"
                    android:contentDescription="@string/comment_options_cd"
                    android:padding="@dimen/icon_button_inset"
                    app:tint="@color/neu_copper_ink_muted"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_replies_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="54dp"
        android:layout_marginTop="@dimen/spacing_xs"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_view_replies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/touch_target_min"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="@string/preview_view_replies"
            android:textColor="@color/neu_copper_accent"
            android:textSize="@dimen/text_banner"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_icon_circle_transparent"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ll_replies_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
