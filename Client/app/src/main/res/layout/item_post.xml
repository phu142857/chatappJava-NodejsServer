<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_neu_copper_list_row"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="true"
    android:orientation="vertical"
    android:paddingStart="@dimen/margin_mobile"
    android:paddingTop="@dimen/spacing_md"
    android:paddingEnd="@dimen/margin_mobile"
    android:paddingBottom="@dimen/spacing_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="@dimen/spacing_sm">

        <FrameLayout
            android:layout_width="@dimen/neu_copper_avatar_well"
            android:layout_height="@dimen/neu_copper_avatar_well"
            android:background="@drawable/bg_neu_copper_sunken_circle"
            android:padding="4dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_post_avatar"
                android:layout_width="@dimen/neu_copper_avatar_inner"
                android:layout_height="@dimen/neu_copper_avatar_inner"
                android:layout_gravity="center"
                android:contentDescription="@string/home_create_post_avatar_cd"
                android:src="@drawable/ic_profile_placeholder"
                app:civ_border_width="0dp" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_post_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:maxLines="1"
                    android:maxWidth="@dimen/post_username_max_width"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold"
                    tools:text="Sophia Nguyen" />

                <TextView
                    android:id="@+id/tv_post_tagged_users"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/post_tagged_margin_start"
                    android:background="@drawable/bg_icon_circle_transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:paddingStart="@dimen/badge_padding_h"
                    android:paddingTop="@dimen/badge_padding_v"
                    android:paddingEnd="@dimen/badge_padding_h"
                    android:paddingBottom="@dimen/badge_padding_v"
                    android:text=""
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body_medium"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_post_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/list_item_margin"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text=""
                android:textColor="@color/neu_copper_accent"
                android:textSize="@dimen/text_timestamp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/iv_post_menu"
            android:layout_width="@dimen/post_menu_button_size"
            android:layout_height="@dimen/post_menu_button_size"
            android:background="@drawable/bg_icon_circle_transparent"
            android:contentDescription="@string/post_options_cd"
            android:padding="@dimen/post_menu_button_padding"
            android:src="@drawable/ic_more"
            app:tint="@color/neu_copper_ink_muted" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/chat_messages_margin_top">

        <TextView
            android:id="@+id/tv_post_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans"
            android:lineSpacingExtra="@dimen/post_content_line_spacing"
            android:maxLines="5"
            android:paddingBottom="@dimen/chat_messages_margin_top"
            android:text=""
            android:textColor="@color/neu_copper_ink"
            android:textSize="@dimen/text_auth_subtitle" />

        <FrameLayout
            android:id="@+id/fl_post_media"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_soft_inset"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:minHeight="@dimen/post_media_min_height"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_post_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:minHeight="@dimen/post_media_min_height"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_post_gallery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:padding="@dimen/list_item_margin"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/fl_post_video"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/video_stage"
                android:minHeight="@dimen/post_video_min_height"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_post_video_thumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:minHeight="@dimen/post_video_min_height"
                    android:scaleType="centerCrop" />

                <ImageButton
                    android:id="@+id/iv_post_video_play"
                    android:layout_width="@dimen/post_play_button_size"
                    android:layout_height="@dimen/post_play_button_size"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_send_circle_modern"
                    android:contentDescription="@string/post_play_video_cd"
                    android:padding="@dimen/post_play_button_padding"
                    android:src="@drawable/ic_play"
                    app:tint="@color/neu_copper_ink" />

            </FrameLayout>

        </FrameLayout>

    </LinearLayout>

    <include
        android:id="@+id/embedded_post_card"
        layout="@layout/item_embedded_post"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingBottom="@dimen/spacing_xs">

        <LinearLayout
            android:id="@+id/ll_likes_summary"
            android:layout_width="0dp"
            android:layout_height="@dimen/post_interaction_row_height"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_circle_transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/spacing_xs"
            android:paddingEnd="@dimen/spacing_xs">

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_emoji_smile"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:id="@+id/tv_likes_count"
                android:importantForAccessibility="no"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/post_tagged_margin_start"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text=""
                tools:text="1.2K"
                android:textColor="@color/neu_copper_ink"
                android:textSize="@dimen/text_banner"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_comments_count"
            android:layout_width="0dp"
            android:layout_height="@dimen/post_interaction_row_height"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_circle_transparent"
            android:clickable="true"
            android:ellipsize="end"
            android:focusable="true"
            android:gravity="center"
            android:maxLines="1"
            android:contentDescription="@string/post_comment"
            android:text=""
            tools:text="245 comments"
            android:textColor="@color/neu_copper_ink_muted"
            android:textSize="@dimen/text_banner" />

        <TextView
            android:id="@+id/tv_shares_count"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/post_interaction_row_height"
            android:background="@drawable/bg_icon_circle_transparent"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="@dimen/chat_messages_margin_top"
            android:paddingEnd="@dimen/chat_messages_margin_top"
            android:contentDescription="@string/post_share"
            android:text=""
            tools:text="12 shares"
            android:textColor="@color/neu_copper_ink_muted"
            android:textSize="@dimen/text_banner" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:layout_marginTop="@dimen/list_item_margin"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:background="@color/md3_border_subtle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/ll_like_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/post_action_row_height"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_circle_transparent"
            android:clickable="true"
            android:contentDescription="@string/post_like"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_like_icon"
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_emoji_smile"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:id="@+id/tv_like_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/post_action_icon_margin"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/post_like"
                android:textColor="@color/neu_copper_ink"
                android:textSize="@dimen/text_body_medium"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_comment_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/post_action_row_height"
            android:layout_marginStart="@dimen/spacing_xs"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_circle_transparent"
            android:clickable="true"
            android:contentDescription="@string/post_comment"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chat"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/post_action_icon_margin"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/post_comment"
                android:textColor="@color/neu_copper_ink"
                android:textSize="@dimen/text_body_medium"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_share_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/post_action_row_height"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_circle_transparent"
            android:clickable="true"
            android:contentDescription="@string/post_share"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_open"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/post_action_icon_margin"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/post_share"
                android:textColor="@color/neu_copper_ink"
                android:textSize="@dimen/text_body_medium"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
