<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dialog_padding_h"
        android:paddingEnd="@dimen/dialog_padding_h"
        android:paddingTop="@dimen/dialog_padding_v"
        android:paddingBottom="@dimen/dialog_padding_h"
        android:background="@drawable/bg_neu_emboss_raised_md">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_share_post_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="@dimen/dialog_padding_h" />

        <!-- Share to Feed -->
        <LinearLayout
            android:id="@+id/option_share_to_feed"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_edit"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_share_to_feed"
                style="@style/AppBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Send as Message -->
        <LinearLayout
            android:id="@+id/option_send_as_message"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_send"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_share_as_message"
                style="@style/AppBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Share to Story -->
        <LinearLayout
            android:id="@+id/option_share_to_story"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_info"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_share_to_story"
                style="@style/AppBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Share to Group/Page -->
        <LinearLayout
            android:id="@+id/option_share_to_group"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_group_icon"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_share_to_group"
                style="@style/AppBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/md3_border_subtle"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Copy Link -->
        <LinearLayout
            android:id="@+id/option_copy_link"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_link"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_share_copy_link"
                style="@style/AppBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Share to External Apps -->
        <LinearLayout
            android:id="@+id/option_share_external"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="@dimen/chat_messages_margin_top"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_link"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_share_other_apps"
                style="@style/AppBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>