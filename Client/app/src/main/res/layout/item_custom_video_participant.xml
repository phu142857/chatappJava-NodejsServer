<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:background="@drawable/bg_soft_inset"
        android:clipChildren="false"
        android:clipToPadding="false">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/video_stage">

            <ImageView
                android:id="@+id/iv_video_frame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/video_placeholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/video_stage_soft"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_participant_avatar"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:src="@drawable/ic_profile_placeholder"
                    app:civ_border_color="@color/md3_border_subtle"
                    app:civ_border_width="@dimen/avatar_border_width" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/call_camera_off"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:textSize="@dimen/text_banner"
                    android:textStyle="bold" />

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_connection_quality"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/spacing_sm"
                android:background="@drawable/bg_icon_circle_dark"
                android:padding="8dp"
                android:src="@drawable/ic_signal"
                android:visibility="gone"
                app:tint="@color/success_color" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_overlay"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tv_participant_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:maxLines="1"
                    android:text="@string/settings_default_user"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="@dimen/text_body_medium"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_muted_indicator"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="8dp"
                    android:src="@drawable/ic_mic_off"
                    android:visibility="gone"
                    app:tint="@color/neu_copper_accent" />

            </LinearLayout>

        </FrameLayout>

    </RelativeLayout>

</FrameLayout>
