<?xml version="1.0" encoding="utf-8"?>
<!-- Neumorphic Copper search field: icon + EditText + optional clear -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/neu_copper_search_height"
    android:background="@drawable/bg_neu_copper_sunken_pill"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/iv_search_icon"
        android:layout_width="@dimen/icon_search"
        android:layout_height="@dimen/icon_search"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/spacing_lg"
        android:contentDescription="@string/search_icon_description"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_search"
        app:tint="@color/neu_copper_ink_muted" />

    <EditText
        android:id="@+id/et_search"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignWithParentIfMissing="true"
        android:layout_toEndOf="@id/iv_search_icon"
        android:layout_toStartOf="@id/iv_clear"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/spacing_xs"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        android:hint="@string/search_hint"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:singleLine="true"
        android:textColor="@color/neu_copper_ink"
        android:textColorHint="@color/neu_copper_ink_muted"
        android:textCursorDrawable="@null"
        android:textSize="@dimen/text_body_medium"
        tools:ignore="TouchTargetSizeCheck" />

    <ImageButton
        android:id="@+id/iv_clear"
        android:layout_width="@dimen/touch_target_min"
        android:layout_height="@dimen/touch_target_min"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="@dimen/spacing_xs"
        android:background="@drawable/bg_icon_circle_transparent"
        android:contentDescription="@string/clear_search_cd"
        android:padding="@dimen/icon_button_inset"
        android:src="@drawable/ic_close"
        android:visibility="gone"
        app:tint="@color/neu_copper_ink_muted" />

</RelativeLayout>
