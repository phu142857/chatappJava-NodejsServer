<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dialog_padding_h"
        android:paddingEnd="@dimen/dialog_padding_h"
        android:paddingTop="@dimen/dialog_padding_v"
        android:paddingBottom="@dimen/dialog_padding_h"
        android:background="@drawable/bg_neu_emboss_raised_md">

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_message_options_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/neu_copper_ink"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="@dimen/dialog_padding_h" />

        <!-- React Option -->
        <LinearLayout
            android:id="@+id/option_react"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_emoji_smile"
                android:layout_marginEnd="12dp"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/AppBodyLarge"
                android:text="@string/dialog_option_react"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Reply Option -->
        <LinearLayout
            android:id="@+id/option_reply"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_restore"
                android:layout_marginEnd="12dp"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/AppBodyLarge"
                android:text="@string/dialog_option_reply"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Edit Option -->
        <LinearLayout
            android:id="@+id/option_edit"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_edit"
                android:layout_marginEnd="12dp"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/AppBodyLarge"
                android:text="@string/dialog_option_edit"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Copy Option -->
        <LinearLayout
            android:id="@+id/option_copy"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_open"
                android:layout_marginEnd="12dp"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/AppBodyLarge"
                android:text="@string/dialog_option_copy"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Forward Option -->
        <LinearLayout
            android:id="@+id/option_forward"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_open"
                android:layout_marginEnd="12dp"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/AppBodyLarge"
                android:text="@string/dialog_option_forward"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- View Info Option -->
        <LinearLayout
            android:id="@+id/option_view_info"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_info"
                android:layout_marginEnd="12dp"
                app:tint="@color/neu_copper_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/AppBodyLarge"
                android:text="@string/dialog_option_view_info"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Delete Option -->
        <LinearLayout
            android:id="@+id/option_delete"
            android:layout_width="match_parent"
            android:layout_height="@dimen/option_row_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_danger_option_row"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_delete"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_error" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_option_delete"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/dialog_button_destructive_text"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>