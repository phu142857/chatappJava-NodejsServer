<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_neu_emboss_raised_md">

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_change_password_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="20dp" />

        <!-- Current Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialog_current_password"
            style="@style/AppLabelSmall"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_current_password"
            style="@style/AppInputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColorHint="@color/md3_on_surface_secondary"
            android:hint="@string/hint_current_password"
            android:textCursorDrawable="@null"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- New Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialog_new_password"
            style="@style/AppLabelSmall"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_new_password"
            style="@style/AppInputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColorHint="@color/md3_on_surface_secondary"
            android:hint="@string/hint_new_password"
            android:textCursorDrawable="@null"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Confirm Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialog_confirm_new_password"
            style="@style/AppLabelSmall"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_confirm_password"
            style="@style/AppInputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColorHint="@color/md3_on_surface_secondary"
            android:hint="@string/hint_confirm_new_password"
            android:textCursorDrawable="@null"
            android:layout_marginBottom="@dimen/screen_edge_inset" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btn_cancel_password"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target_min"
                android:minWidth="92dp"
                android:layout_marginEnd="10dp"
                android:text="@string/action_cancel"
                android:textAllCaps="false"
                android:textColor="@color/dialog_button_secondary_text"
                android:textSize="14sp"
                android:textStyle="bold"
                style="@style/DialogButton.Secondary"
                android:paddingStart="@dimen/dialog_padding_h"
                android:paddingEnd="@dimen/dialog_padding_h" />

            <Button
                android:id="@+id/btn_save_password"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target_min"
                android:minWidth="92dp"
                android:text="@string/action_save"
                android:textAllCaps="false"
                android:textColor="@color/dialog_button_filled_text"
                android:textSize="14sp"
                android:textStyle="bold"
                style="@style/DialogButton.Filled"
                android:paddingStart="22dp"
                android:paddingEnd="22dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>