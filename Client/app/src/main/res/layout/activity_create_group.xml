<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_neu_copper_canvas"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/header_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width">

        <include
            android:id="@+id/create_group_toolbar"
            layout="@layout/component_neu_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tv_create"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/touch_target_min"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="@dimen/margin_mobile"
            android:minWidth="82dp"
            android:background="@drawable/bg_neu_copper_fab"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingStart="@dimen/dialog_padding_h"
            android:paddingEnd="@dimen/dialog_padding_h"
            android:text="@string/action_create"
            android:textAllCaps="false"
            android:textColor="@color/neu_copper_ink"
            android:textSize="14sp"
            android:textStyle="bold" />

    </FrameLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/spacing_md"
        android:orientation="vertical"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width">

        <!-- Group Information Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:background="@drawable/bg_soft_inset"
            android:paddingStart="@dimen/dialog_padding_h"
            android:paddingEnd="@dimen/dialog_padding_h"
            android:paddingTop="@dimen/dialog_padding_v"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_info_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/neu_copper_ink"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Group Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_name_placeholder"
                android:textSize="13sp"
                android:textColor="@color/neu_copper_ink_muted"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_group_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/group_name_hint"
                android:inputType="textCapWords"
                android:textSize="15sp"
                android:textColor="@color/neu_copper_ink"
                android:textColorHint="@color/neu_copper_ink_muted"
                android:background="@drawable/bg_soft_inset"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:textCursorDrawable="@null"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Group Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_description_label"
                android:textSize="13sp"
                android:textColor="@color/neu_copper_ink_muted"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_group_description"
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:hint="@string/group_description_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:textSize="15sp"
                android:textColor="@color/neu_copper_ink"
                android:textColorHint="@color/neu_copper_ink_muted"
                android:background="@drawable/bg_soft_inset"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:gravity="top|start"
                android:textCursorDrawable="@null"
                android:layout_marginBottom="16dp" />

            <!-- Public/Private Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/group_public_label"
                        android:textSize="16sp"
                        android:textColor="@color/neu_copper_ink"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/group_public_desc"
                        android:textSize="12sp"
                        android:textColor="@color/neu_copper_ink_muted"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switch_public"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/neu_copper_accent"
                    android:trackTint="@color/switch_track_selector" />

            </LinearLayout>

        </LinearLayout>

        <!-- Friends Selection Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_soft_inset"
            android:paddingStart="@dimen/dialog_padding_h"
            android:paddingEnd="@dimen/dialog_padding_h"
            android:paddingTop="@dimen/dialog_padding_v"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_select_friends"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/neu_copper_ink"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/group_select_friends_hint"
                android:textSize="13sp"
                android:textColor="@color/neu_copper_ink_muted"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Search — same sizing as Home search trench -->
            <include
                android:id="@+id/search_bar_home"
                layout="@layout/component_neu_search_field"
                android:layout_width="match_parent"
                android:layout_height="@dimen/neu_copper_search_height"
                android:layout_marginBottom="12dp" />

            <include
                android:id="@+id/list_skeleton"
                layout="@layout/component_list_skeleton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Friends RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_friends"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:scrollbars="none" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>