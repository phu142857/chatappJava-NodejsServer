<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dialog_padding_h"
        android:paddingEnd="@dimen/dialog_padding_h"
        android:paddingTop="@dimen/dialog_padding_v"
        android:paddingBottom="@dimen/dialog_padding_h"
        android:background="@drawable/bg_neu_emboss_raised_md">

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_attachment_select_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/md3_on_surface"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="@dimen/dialog_padding_h" />

        <!-- Camera Option -->
        <LinearLayout
            android:id="@+id/option_camera"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_camera"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/AppBodyLarge"
                android:text="@string/dialog_attachment_take_photo"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Gallery Option -->
        <LinearLayout
            android:id="@+id/option_gallery"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_image"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/AppBodyLarge"
                android:text="@string/dialog_attachment_gallery"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- File Upload Option -->
        <LinearLayout
            android:id="@+id/option_file"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_file"
                android:layout_marginEnd="12dp"
                app:tint="@color/md3_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/AppBodyLarge"
                android:text="@string/dialog_attachment_file"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Remove Avatar Option -->
        <LinearLayout
            android:id="@+id/option_remove_avatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/btn_remove_avatar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/option_row_height"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_danger_option_row"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_delete"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/md3_error" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dialog_attachment_remove_avatar"
                    android:textSize="@dimen/text_body_large"
                    android:textColor="@color/dialog_button_destructive_text"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>