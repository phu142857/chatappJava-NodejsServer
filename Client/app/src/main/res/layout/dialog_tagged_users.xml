<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dialog_padding_h"
        android:paddingEnd="@dimen/dialog_padding_h"
        android:paddingTop="@dimen/dialog_padding_v"
        android:paddingBottom="@dimen/dialog_padding_h"
        android:background="@drawable/bg_neu_emboss_raised_md">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_tagged_users_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="@dimen/dialog_padding_h" />

        <!-- Tagged Users List Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:orientation="vertical"
            android:background="@drawable/bg_option_row_dark"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tagged_users"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:nestedScrollingEnabled="true"
                android:clipToPadding="false"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:scrollbars="none"
                android:overScrollMode="never" />

        </LinearLayout>

        <!-- Close Button -->
        <Button
            android:id="@+id/btn_close"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/close_cd"
            android:textAllCaps="false"
            android:textColor="@color/dialog_button_filled_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/spacing_md"
            style="@style/DialogButton.Filled"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

</LinearLayout>