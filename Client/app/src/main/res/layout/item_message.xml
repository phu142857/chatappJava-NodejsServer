<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/spacing_xs"
    android:paddingEnd="@dimen/spacing_xs"
    android:paddingTop="@dimen/list_item_margin"
    android:paddingBottom="@dimen/list_item_margin"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Sent Message -->
    <LinearLayout
        android:id="@+id/ll_sent_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginEnd="@dimen/list_item_margin"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/ll_sent_reply_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/message_reply_max_width"
                android:orientation="vertical"
                android:background="@drawable/bg_message_reply_sent"
                android:paddingStart="@dimen/chat_messages_margin_top"
                android:paddingEnd="@dimen/chat_messages_margin_top"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingBottom="@dimen/spacing_xs"
                android:layout_marginBottom="@dimen/list_item_margin"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_sent_reply_thumb"
                    android:layout_width="@dimen/reply_thumb_width"
                    android:layout_height="@dimen/reply_thumb_height"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:background="@drawable/bg_soft_inset"
                    android:importantForAccessibility="no"
                    android:visibility="gone"
                    tools:src="@drawable/ic_profile_placeholder" />

                <TextView
                    android:id="@+id/tv_sent_reply_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/neu_copper_ink"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_body_small"
                    tools:text="Alice" />

                <TextView
                    android:id="@+id/tv_sent_reply_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="230dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:textSize="@dimen/text_body_small"
                    android:lineSpacingExtra="2dp"
                    tools:text="Previous message content preview" />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/fl_sent_bubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/tv_sent_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="@dimen/message_bubble_max_width"
                    android:background="@drawable/bg_message_sent"
                    android:paddingStart="@dimen/bubble_padding_h"
                    android:paddingTop="@dimen/bubble_padding_v"
                    android:paddingEnd="@dimen/bubble_padding_h"
                    android:paddingBottom="@dimen/bubble_timestamp_padding_bottom"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/bubble_sent_ink"
                    android:textSize="@dimen/text_body_medium"
                    android:lineSpacingExtra="3dp"
                    tools:text="This is a sent message" />

                <ImageView
                    android:id="@+id/iv_sent_reaction_image"
                    android:layout_width="@dimen/reaction_badge_size"
                    android:layout_height="@dimen/reaction_badge_size"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:translationX="4dp"
                    android:translationY="7dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="3dp"
                    android:visibility="gone"
                    tools:src="@drawable/ic_launcher_foreground" />

            </FrameLayout>

            <include
                android:id="@+id/ll_sent_voice_message"
                layout="@layout/item_voice_message_sent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_sent_edited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/list_item_margin"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/message_edited"
                android:textSize="@dimen/text_timestamp"
                android:textColor="@color/neu_copper_ink_muted"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/fl_sent_image_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/list_item_margin"
                android:layout_marginBottom="@dimen/list_item_margin"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_sent_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="250dp"
                    android:maxHeight="300dp"
                    android:minWidth="130dp"
                    android:minHeight="130dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_image_message_sent"
                    android:padding="2dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground" />

                <ImageView
                    android:id="@+id/iv_sent_image_reaction"
                    android:layout_width="@dimen/reaction_badge_size"
                    android:layout_height="@dimen/reaction_badge_size"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:translationX="4dp"
                    android:translationY="7dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="3dp"
                    android:visibility="gone" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/list_item_margin"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_sent_status"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="4dp"
                    android:importantForAccessibility="yes"
                    android:visibility="gone"
                    tools:src="@drawable/ic_message_sent"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tv_sent_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="@dimen/text_timestamp"
                    android:textColor="@color/neu_copper_ink_muted"
                    tools:text="10:30 AM" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Received Message -->
    <LinearLayout
        android:id="@+id/ll_received_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:layout_marginStart="@dimen/list_item_margin"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_sender_avatar"
            android:layout_width="@dimen/message_avatar_sm"
            android:layout_height="@dimen/message_avatar_sm"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="7dp"
            android:layout_marginTop="@dimen/list_item_margin"
            android:src="@drawable/ic_profile_placeholder"
            android:contentDescription="@string/open_profile_cd"
            app:civ_border_width="@dimen/avatar_border_width_sm"
            app:civ_border_color="@color/md3_border_subtle" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="start"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/ll_received_reply_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/message_reply_max_width"
                android:orientation="vertical"
                android:background="@drawable/bg_message_reply_received"
                android:paddingStart="@dimen/chat_messages_margin_top"
                android:paddingEnd="@dimen/chat_messages_margin_top"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingBottom="@dimen/spacing_xs"
                android:layout_marginBottom="@dimen/list_item_margin"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_received_reply_thumb"
                    android:layout_width="@dimen/reply_thumb_width"
                    android:layout_height="@dimen/reply_thumb_height"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:background="@drawable/bg_soft_inset"
                    android:importantForAccessibility="no"
                    android:visibility="gone"
                    tools:src="@drawable/ic_profile_placeholder" />

                <TextView
                    android:id="@+id/tv_received_reply_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/neu_copper_ink"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_body_small"
                    tools:text="Bob" />

                <TextView
                    android:id="@+id/tv_received_reply_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="230dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/neu_copper_ink_muted"
                    android:textSize="@dimen/text_body_small"
                    android:lineSpacingExtra="2dp"
                    tools:text="Previous message content preview" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_sender_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/neu_copper_accent"
                android:textSize="@dimen/text_body_small"
                android:textStyle="bold"
                android:layout_marginStart="@dimen/list_item_margin"
                android:layout_marginBottom="3dp"
                android:visibility="gone"
                tools:text="Alice" />

            <FrameLayout
                android:id="@+id/fl_received_bubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/tv_received_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="@dimen/message_bubble_max_width"
                    android:background="@drawable/bg_message_received"
                    android:paddingStart="@dimen/bubble_padding_h"
                    android:paddingTop="@dimen/bubble_padding_v"
                    android:paddingEnd="@dimen/bubble_padding_h"
                    android:paddingBottom="@dimen/bubble_timestamp_padding_bottom"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="@dimen/text_body_medium"
                    android:lineSpacingExtra="3dp"
                    tools:text="This is a received message" />

                <ImageView
                    android:id="@+id/iv_received_reaction_image"
                    android:layout_width="@dimen/reaction_badge_size"
                    android:layout_height="@dimen/reaction_badge_size"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:translationX="4dp"
                    android:translationY="7dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="3dp"
                    android:visibility="gone"
                    tools:src="@drawable/ic_launcher_foreground" />

            </FrameLayout>

            <include
                android:id="@+id/ll_received_voice_message"
                layout="@layout/item_voice_message_received"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_received_edited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/list_item_margin"
                android:layout_marginStart="@dimen/spacing_xs"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/message_edited"
                android:textSize="@dimen/text_timestamp"
                android:textColor="@color/neu_copper_ink_muted"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/fl_received_image_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/list_item_margin"
                android:layout_marginBottom="@dimen/list_item_margin"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_received_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="250dp"
                    android:maxHeight="300dp"
                    android:minWidth="130dp"
                    android:minHeight="130dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_image_message_received"
                    android:padding="2dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground" />

                <ImageView
                    android:id="@+id/iv_received_image_reaction"
                    android:layout_width="@dimen/reaction_badge_size"
                    android:layout_height="@dimen/reaction_badge_size"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:translationX="4dp"
                    android:translationY="7dp"
                    android:adjustViewBounds="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_icon_circle_dark"
                    android:padding="3dp"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_received_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/list_item_margin"
                android:layout_marginStart="@dimen/spacing_xs"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="@dimen/text_timestamp"
                android:textColor="@color/neu_copper_ink_muted"
                tools:text="10:30 AM" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
