<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dialog_padding_h"
        android:paddingEnd="@dimen/dialog_padding_h"
        android:paddingTop="@dimen/dialog_padding_v"
        android:paddingBottom="@dimen/dialog_padding_h"
        android:background="@drawable/bg_neu_emboss_raised_md">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reaction_picker_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="@dimen/dialog_padding_h" />

        <!-- Emoji Container -->
        <LinearLayout
            android:id="@+id/container_emojis"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="6"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/bg_option_row_dark"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/emoji_1"
                android:layout_width="0dp"
                android:layout_height="@dimen/reaction_picker_cell"
                android:layout_weight="1"
                android:text="@string/emoji_reaction_like"
                android:textSize="26sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent" />

            <TextView
                android:id="@+id/emoji_2"
                android:layout_width="0dp"
                android:layout_height="@dimen/reaction_picker_cell"
                android:layout_weight="1"
                android:text="@string/emoji_reaction_love"
                android:textSize="26sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent" />

            <TextView
                android:id="@+id/emoji_3"
                android:layout_width="0dp"
                android:layout_height="@dimen/reaction_picker_cell"
                android:layout_weight="1"
                android:text="@string/emoji_reaction_haha"
                android:textSize="26sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent" />

            <TextView
                android:id="@+id/emoji_4"
                android:layout_width="0dp"
                android:layout_height="@dimen/reaction_picker_cell"
                android:layout_weight="1"
                android:text="@string/emoji_reaction_wow"
                android:textSize="26sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent" />

            <TextView
                android:id="@+id/emoji_5"
                android:layout_width="0dp"
                android:layout_height="@dimen/reaction_picker_cell"
                android:layout_weight="1"
                android:text="@string/emoji_reaction_sad"
                android:textSize="26sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent" />

            <TextView
                android:id="@+id/emoji_6"
                android:layout_width="0dp"
                android:layout_height="@dimen/reaction_picker_cell"
                android:layout_weight="1"
                android:text="@string/emoji_reaction_fire"
                android:textSize="26sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent" />

        </LinearLayout>

        <!-- Remove Reaction Button -->
        <LinearLayout
            android:id="@+id/btn_remove_react"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_danger_option_row"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reaction_remove"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/dialog_button_destructive_text"
                android:textSize="15sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>