<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/header_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width">

        <include
            android:id="@+id/profile_view_toolbar"
            layout="@layout/component_neu_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <ImageButton
            android:id="@+id/iv_more"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="@dimen/margin_mobile"
            android:background="@drawable/bg_neu_copper_sunken_circle"
            android:contentDescription="@string/profile_more_cd"
            android:padding="@dimen/icon_button_inset"
            android:src="@drawable/ic_more"
            app:tint="@color/neu_copper_ink_muted" />

    </FrameLayout>

    <!-- Profile Content -->
    <LinearLayout
        android:id="@+id/profile_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/spacing_md"
        android:orientation="vertical"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="8dp">

                <!-- Avatar Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_soft_inset"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="24dp"
                    android:layout_marginBottom="12dp">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/civ_avatar"
                        android:layout_width="108dp"
                        android:layout_height="108dp"
                        android:src="@drawable/ic_profile_placeholder"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@color/md3_border_glow" />

                    <TextView
                        android:id="@+id/tv_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/username"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/neu_copper_ink"
                        android:layout_marginTop="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_view_subtitle"
                        android:textSize="13sp"
                        android:textColor="@color/neu_copper_ink_muted"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Personal Information -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_soft_inset"
                    android:paddingStart="@dimen/dialog_padding_h"
                    android:paddingEnd="@dimen/dialog_padding_h"
                    android:paddingTop="@dimen/dialog_padding_v"
                    android:paddingBottom="@dimen/dialog_padding_h">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_personal_info"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/neu_copper_ink"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- First Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_option_row_dark"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="105dp"
                            android:layout_height="wrap_content"
                            android:text="@string/first_name"
                            android:textSize="13sp"
                            android:textColor="@color/neu_copper_ink_muted" />

                        <TextView
                            android:id="@+id/tv_first_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="14sp"
                            android:textColor="@color/neu_copper_ink"
                            android:textStyle="bold"
                            tools:text="John" />

                    </LinearLayout>

                    <!-- Last Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_option_row_dark"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="105dp"
                            android:layout_height="wrap_content"
                            android:text="@string/last_name"
                            android:textSize="13sp"
                            android:textColor="@color/neu_copper_ink_muted" />

                        <TextView
                            android:id="@+id/tv_last_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="14sp"
                            android:textColor="@color/neu_copper_ink"
                            android:textStyle="bold"
                            tools:text="Doe" />

                    </LinearLayout>

                    <!-- Email -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_option_row_dark"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="105dp"
                            android:layout_height="wrap_content"
                            android:text="@string/label_email"
                            android:textSize="13sp"
                            android:textColor="@color/neu_copper_ink_muted" />

                        <TextView
                            android:id="@+id/tv_email"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="14sp"
                            android:textColor="@color/neu_copper_ink"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end"
                            tools:text="john.doe@example.com" />

                    </LinearLayout>

                    <!-- Phone -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_option_row_dark"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:layout_width="105dp"
                            android:layout_height="wrap_content"
                            android:text="@string/label_phone"
                            android:textSize="13sp"
                            android:textColor="@color/neu_copper_ink_muted" />

                        <TextView
                            android:id="@+id/tv_phone_number"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="14sp"
                            android:textColor="@color/neu_copper_ink"
                            android:textStyle="bold"
                            tools:text="+123456789" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Bio Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_soft_inset"
                    android:paddingStart="@dimen/dialog_padding_h"
                    android:paddingEnd="@dimen/dialog_padding_h"
                    android:paddingTop="@dimen/dialog_padding_v"
                    android:paddingBottom="@dimen/dialog_padding_h">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_about"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/neu_copper_ink"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_bio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/neu_copper_ink"
                        android:lineSpacingExtra="4dp"
                        tools:text="This is a sample bio text that describes the user." />

                </LinearLayout>

                <!-- Friends Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_soft_inset"
                    android:paddingStart="@dimen/dialog_padding_h"
                    android:paddingEnd="@dimen/dialog_padding_h"
                    android:paddingTop="@dimen/dialog_padding_v"
                    android:paddingBottom="@dimen/dialog_padding_h">

                    <TextView
                        android:id="@+id/tv_friends_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_friends"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/neu_copper_ink"
                        android:layout_marginBottom="10dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_friends"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:scrollbars="none"
                        tools:listitem="@layout/item_user_search" />

                    <TextView
                        android:id="@+id/tv_no_friends"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/empty_friends_title"
                        android:textSize="14sp"
                        android:textColor="@color/neu_copper_ink_muted"
                        android:visibility="gone"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <!-- Posts Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_soft_inset"
                    android:paddingStart="@dimen/dialog_padding_h"
                    android:paddingEnd="@dimen/dialog_padding_h"
                    android:paddingTop="@dimen/dialog_padding_v"
                    android:paddingBottom="@dimen/dialog_padding_h">

                    <TextView
                        android:id="@+id/tv_posts_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_posts"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/neu_copper_ink"
                        android:layout_marginBottom="10dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_posts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:scrollbars="none" />

                    <TextView
                        android:id="@+id/tv_no_posts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/empty_posts_title"
                        android:textSize="14sp"
                        android:textColor="@color/neu_copper_ink_muted"
                        android:visibility="gone"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>