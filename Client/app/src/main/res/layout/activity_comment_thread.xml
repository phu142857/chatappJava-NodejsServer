<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width">

        <include
            android:id="@+id/comment_toolbar"
            layout="@layout/component_neu_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Sorting Options -->
        <LinearLayout
            android:id="@+id/ll_sort_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_sort_relevant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/comments_sort_relevant"
                android:textColor="@color/neu_copper_ink"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_small_pill"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tv_sort_recent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/comments_sort_recent"
                android:textColor="@color/neu_copper_ink_muted"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_circle_transparent"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Original Post Summary -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_post_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginEnd="@dimen/margin_mobile"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/app_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@drawable/bg_soft_inset">

            <!-- Post Author Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="10dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_post_author_avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_profile_placeholder"
                    app:civ_border_color="@color/md3_border_glow"
                    app:civ_border_width="1.5dp" />

                <TextView
                    android:id="@+id/tv_post_author_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/author_name_placeholder"
                    android:textColor="@color/neu_copper_ink"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_post_content_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/post_content_preview"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:ellipsize="end" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <include
        android:id="@+id/list_skeleton"
        layout="@layout/component_list_skeleton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cv_post_summary" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/ll_empty_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="34dp"
        android:paddingBottom="34dp"
        android:visibility="gone"
        android:background="@drawable/bg_soft_inset"
        app:layout_constraintTop_toBottomOf="@id/cv_post_summary"
        app:layout_constraintBottom_toTopOf="@id/ll_input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:src="@drawable/ic_chat"
            android:background="@drawable/bg_icon_circle_dark"
            android:padding="16dp"
            app:tint="@color/neu_copper_accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/comments_empty_title"
            android:textColor="@color/neu_copper_ink"
            android:textStyle="bold"
            android:textSize="19sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/comments_empty_subtitle"
            android:textColor="@color/neu_copper_ink_muted"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Comments RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_comments"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/cv_post_summary"
        app:layout_constraintBottom_toTopOf="@id/tv_load_more_comments"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width" />

    <!-- Load More Comments Button -->
    <TextView
        android:id="@+id/tv_load_more_comments"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/comments_view_more"
        android:textColor="@color/neu_copper_ink"
        android:textSize="13sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_new_message_button"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/rv_comments"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ll_reply_indicator" />

    <!-- Reply Indicator -->
    <LinearLayout
        android:id="@+id/ll_reply_indicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:background="@drawable/bg_reply_bar_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_sm"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/ll_input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="3dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_reply_line" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_replying_to"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/replying_to"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_white" />

            <TextView
                android:id="@+id/tv_reply_target_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/username"
                android:textSize="14sp"
                android:textColor="@color/neu_copper_ink"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/iv_cancel_reply"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="@drawable/bg_icon_circle_dark"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/close_reply_description"
            android:padding="@dimen/icon_button_inset"
            app:tint="@color/neu_copper_ink_muted" />

    </LinearLayout>

    <!-- Flat comment input dock -->
    <LinearLayout
        android:id="@+id/ll_input_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neu_composer_dock"
        android:gravity="center_vertical"
        android:minHeight="@dimen/nav_bar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingBottom="@dimen/spacing_xs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="@dimen/home_content_max_width">

        <!-- Comment Field -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="@dimen/search_bar_height"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/bg_soft_inset">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_comment_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_profile_placeholder"
                app:civ_border_color="@color/md3_border_glow"
                app:civ_border_width="1dp" />

            <EditText
                android:id="@+id/et_comment_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:minHeight="40dp"
                android:maxHeight="120dp"
                android:background="@android:color/transparent"
                android:hint="@string/comment_hint"
                android:textColorHint="@color/neu_copper_ink_muted"
                android:textColor="@color/neu_copper_ink"
                android:textSize="14sp"
                android:inputType="textCapSentences|textMultiLine"
                android:gravity="center_vertical|start"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:textCursorDrawable="@null"
                android:scrollbars="vertical"
                android:overScrollMode="always" />

            <ImageButton
                android:id="@+id/iv_attach_media"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:background="@drawable/bg_icon_circle_transparent"
                android:src="@drawable/ic_camera"
                android:contentDescription="@string/attach_media_cd"
                android:padding="@dimen/icon_button_inset"
                android:visibility="visible"
                app:tint="@color/neu_copper_accent" />

        </LinearLayout>

        <!-- Send Button Outside -->
        <ImageButton
            android:id="@+id/iv_send_comment"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_send_circle_modern"
            android:src="@drawable/ic_send"
            android:contentDescription="@string/send_comment_cd"
            android:padding="@dimen/icon_button_inset"
            android:enabled="false"
            app:tint="@color/neu_copper_ink" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>