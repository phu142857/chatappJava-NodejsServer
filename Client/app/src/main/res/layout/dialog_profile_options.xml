<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:soundEffectsEnabled="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neu_emboss_raised_md"
        android:orientation="vertical"
        android:paddingStart="@dimen/dialog_padding_h"
        android:paddingTop="@dimen/dialog_padding_v"
        android:paddingEnd="@dimen/dialog_padding_h"
        android:paddingBottom="@dimen/dialog_padding_h">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingStart="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_xs"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingBottom="@dimen/dialog_padding_h"
            android:text="@string/profile_options_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/md3_on_surface" />

        <LinearLayout
            android:id="@+id/option_send_message"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="@dimen/chat_messages_margin_top"
            android:contentDescription="@string/profile_send_message">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_send"
                app:tint="@color/md3_primary" />

            <TextView
                style="@style/AppBodyMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_send_message"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/option_add_friend"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="@dimen/chat_messages_margin_top"
            android:contentDescription="@string/profile_add_friend"
            android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_add"
                app:tint="@color/md3_primary" />

            <TextView
                style="@style/AppBodyMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_add_friend"
                android:textColor="@color/md3_on_surface"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/option_unfriend"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="@dimen/chat_messages_margin_top"
            android:background="@drawable/bg_danger_option_row"
            android:contentDescription="@string/profile_unfriend"
            android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_delete"
                app:tint="@color/md3_error" />

            <TextView
                style="@style/AppBodyMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_unfriend"
                android:textColor="@color/dialog_button_destructive_text"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/option_report"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:layout_marginBottom="@dimen/chat_messages_margin_top"
            android:background="@drawable/bg_danger_option_row"
            android:contentDescription="@string/profile_report">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_info"
                app:tint="@color/md3_error" />

            <TextView
                style="@style/AppBodyMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_report"
                android:textColor="@color/dialog_button_destructive_text"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/option_block_user"
            style="@style/AppOptionRow"
            android:layout_width="match_parent"
            android:background="@drawable/bg_danger_option_row"
            android:contentDescription="@string/profile_block_user">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_close"
                app:tint="@color/md3_error" />

            <TextView
                style="@style/AppBodyMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_block_user"
                android:textColor="@color/dialog_button_secondary_text"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
