<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_chat_screen_dark">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="@dimen/header_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingBottom="@dimen/spacing_sm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans"
                android:maxLines="1"
                android:text="@string/call_group_title"
                android:textColor="@color/neu_copper_ink"
                android:textSize="@dimen/text_headline_medium"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_participant_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="@string/call_participant_count"
                android:textColor="@color/neu_copper_ink_muted"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_call_duration"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/touch_target_min"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_neu_copper_sunken_pill"
            android:gravity="center"
            android:minWidth="72dp"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:text="@string/call_timer_placeholder"
            android:textColor="@color/neu_copper_ink"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Video participants grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_video_grid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_xs"
        android:layout_marginEnd="@dimen/spacing_xs"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:clipToPadding="false"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/call_controls_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_custom_video_participant" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="34dp"
        android:paddingBottom="34dp"
        android:background="@drawable/bg_empty_state_panel"
        app:layout_constraintTop_toTopOf="@id/rv_video_grid"
        app:layout_constraintBottom_toBottomOf="@id/rv_video_grid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:src="@drawable/ic_video_call"
            android:background="@drawable/bg_icon_circle_dark"
            android:padding="16dp"
            android:layout_marginBottom="@dimen/spacing_md"
            app:tint="@color/md3_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/call_waiting_others"
            android:textColor="@color/md3_on_surface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:gravity="center" />

    </LinearLayout>

    <!-- Flat call control dock -->
    <LinearLayout
        android:id="@+id/call_controls_container"
        android:layout_width="0dp"
        android:layout_height="@dimen/call_controls_dock_height"
        android:background="@drawable/bg_neu_composer_dock"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_mute"
            android:layout_width="@dimen/call_control_button_size"
            android:layout_height="@dimen/call_control_button_size"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="@string/call_mute_cd"
            android:src="@drawable/ic_mic"
            android:scaleType="centerInside"
            android:padding="14dp"
            app:tint="@color/neu_copper_accent" />

        <ImageButton
            android:id="@+id/btn_camera_toggle"
            android:layout_width="@dimen/call_control_button_size"
            android:layout_height="@dimen/call_control_button_size"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="@string/call_camera_off_cd"
            android:src="@drawable/ic_video_call"
            android:scaleType="centerInside"
            android:padding="14dp"
            app:tint="@color/neu_copper_accent" />

        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="@dimen/call_control_button_size"
            android:layout_height="@dimen/call_control_button_size"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_icon_circle_dark"
            android:contentDescription="@string/call_switch_camera_cd"
            android:src="@drawable/ic_switch_camera"
            android:scaleType="centerInside"
            android:padding="14dp"
            app:tint="@color/neu_copper_ink_muted" />

        <ImageButton
            android:id="@+id/btn_end_call"
            android:layout_width="@dimen/call_end_button_size"
            android:layout_height="@dimen/call_end_button_size"
            android:background="@drawable/bg_call_decline_circle"
            android:contentDescription="@string/call_end_cd"
            android:src="@drawable/ic_end_call"
            android:padding="16dp"
            android:scaleType="centerInside"
            app:tint="@color/text_white" />

    </LinearLayout>

    <!-- Loading overlay -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/call_overlay_scrim"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/md3_primary" />

        <TextView
            android:id="@+id/tv_loading_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/call_connecting"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>