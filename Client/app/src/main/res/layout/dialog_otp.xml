<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:soundEffectsEnabled="true"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_neu_emboss_raised_md">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_otp_title"
            android:textAppearance="@style/AppHeadlineSmall"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp" />

        <!-- Message -->
        <TextView
            android:id="@+id/tv_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_otp_message"
            style="@style/AppBodyLarge"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="@dimen/dialog_padding_h" />

        <!-- Hidden input to capture numeric OTP -->
        <EditText
            android:id="@+id/dialog_et_hidden_otp"
            android:layout_width="1px"
            android:layout_height="1px"
            android:inputType="number"
            android:digits="0123456789"
            android:maxLength="6"
            android:singleLine="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:cursorVisible="false"
            android:importantForAutofill="no"
            android:alpha="0"
            android:visibility="visible" />

        <!-- OTP Circles Container -->
        <LinearLayout
            android:id="@+id/otp_circles_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_option_row_dark">

            <TextView
                android:id="@+id/otp_c1"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:gravity="center"
                android:textColor="@color/md3_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_icon_circle_dark" />

            <Space
                android:layout_width="9dp"
                android:layout_height="0dp" />

            <TextView
                android:id="@+id/otp_c2"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:gravity="center"
                android:textColor="@color/md3_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_icon_circle_dark" />

            <Space
                android:layout_width="9dp"
                android:layout_height="0dp" />

            <TextView
                android:id="@+id/otp_c3"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:gravity="center"
                android:textColor="@color/md3_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_icon_circle_dark" />

            <Space
                android:layout_width="9dp"
                android:layout_height="0dp" />

            <TextView
                android:id="@+id/otp_c4"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:gravity="center"
                android:textColor="@color/md3_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_icon_circle_dark" />

            <Space
                android:layout_width="9dp"
                android:layout_height="0dp" />

            <TextView
                android:id="@+id/otp_c5"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:gravity="center"
                android:textColor="@color/md3_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_icon_circle_dark" />

            <Space
                android:layout_width="9dp"
                android:layout_height="0dp" />

            <TextView
                android:id="@+id/otp_c6"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:gravity="center"
                android:textColor="@color/md3_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_icon_circle_dark" />

        </LinearLayout>

        <!-- Error Message -->
        <TextView
            android:id="@+id/dialog_tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/text_white"
            android:visibility="gone"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <!-- Timer -->
        <TextView
            android:id="@+id/dialog_tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="84dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/otp_timer_initial"
            android:textColor="@color/md3_on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_soft_inset"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- Resend Button -->
        <Button
            android:id="@+id/btn_resend_otp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/action_resend_otp"
            android:textAllCaps="false"
            android:textColor="@color/dialog_button_filled_text"
            android:textSize="15sp"
            android:textStyle="bold"
            style="@style/DialogButton.Filled"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

</LinearLayout>